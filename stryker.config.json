{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.mutation.config.js",
    "enableFindRelatedTests": false
  },
  "concurrency": 1,
  "timeoutMS": 60000,
  "coverageAnalysis": "off",
  "ignorePatterns": [
    ".obsidian-cache",
    "coverage",
    "tmp",
    "docs"
  ],
  "mutate": [
    "src/application/agents/kernel/kernel-tool-registry-adapter.ts",
    "src/application/agents/kernel/json-utils.ts"
  ],
  "thresholds": { "high": 90, "low": 80, "break": 85 },
  "tempDirName": ".stryker-tmp",
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": { "fileName": "tests/mutation/mutation-report.json" }
}
