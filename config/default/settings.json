{
  "version": 1,
  "providers": {
    "defaultModel": "",
    "titleSummaryModel": "",
    "list": []
  },
  "conversations": {
    "title": {
      "mode": "first-message",
      "prompt": "Generate a short, descriptive title (max 6 words) for this conversation:\n\n{conversation}\n\nTitle:"
    },
    "icon": {
      "enabled": true
    },
    "defaultMode": "chat",
    "activeId": null
  },
  "tools": {
    "builtin": [
      {
        "type": "read_file",
        "enabled": true
      },
      {
        "type": "write_file",
        "enabled": true
      },
      {
        "type": "list_files",
        "enabled": true
      },
      {
        "type": "search_files",
        "enabled": true
      },
      {
        "type": "create_note",
        "enabled": true
      },
      {
        "type": "append_to_note",
        "enabled": true
      },
      {
        "type": "update_properties",
        "enabled": true
      },
      {
        "type": "read_canvas",
        "enabled": true
      },
      {
        "type": "update_canvas",
        "enabled": true
      }
    ],
    "mcp": {
      "servers": [],
      "registries": [
        {
          "name": "Official MCP Registry",
          "url": "https://registry.modelcontextprotocol.io/v0/servers",
          "enabled": true
        }
      ]
    },
    "openapi": [],
    "cli": []
  },
  "rag": {
    "enabled": true,
    "retrieval": {
      "chunkSize": 5000,
      "chunkOverlap": 200,
      "topK": 5,
      "similarityThreshold": 0.3,
      "relevanceScoreWeight": 0.7,
      "searchType": "similarity",
      "chunkingStrategy": "sentence",
      "contextWindowLimit": 2000,
      "filterByTag": [],
      "excludeByTag": [
        "exclude-from-rag",
        "draft"
      ]
    },
    "embedding": {
      "model": "",
      "vectorStore": "memory",
      "embedChangedFiles": true,
      "maxTokensPerChunk": 2048,
      "minChunkSize": 50,
      "batchSize": 10,
      "indexingMode": "automatic",
      "includeFileTypes": [
        ".md"
      ],
      "excludeFileTypes": [
        ".git/",
        "node_modules/",
        ".obsidian/"
      ],
      "excludeFolders": []
    },
    "caching": {
      "enabled": false,
      "cacheSize": 50
    },
    "grader": {
      "enabled": true,
      "modelSource": "chat",
      "model": "",
      "promptTemplate": "",
      "parallelProcessing": 5,
      "thresholds": {
        "relevance": 5,
        "accuracy": 7,
        "supportQuality": 6
      }
    },
    "enableCompression": false,
    "reranking": {
      "enabled": false,
      "model": "cross-encoder"
    }
  },
  "search": {
    "web": {
      "enabled": false,
      "provider": "duckduckgo",
      "maxResults": 5,
      "autoTrigger": true,
      "searchLanguage": "en",
      "searchCountry": "US",
      "timeRange": "any"
    }
  },
  "prompts": {
    "system": [
      {
        "id": "default",
        "name": "Default Assistant",
        "content": "You are an Obsidian-native knowledge assistant. Use the user's referenced notes, selections, files, folders, links, tags, and properties as primary context. Cite relevant notes with Obsidian links when useful. For any file, property, tag, link, rename, move, or batch change, propose the change first and wait for explicit user confirmation before modifying the vault.",
        "enabled": true,
        "createdAt": 0,
        "updatedAt": 0
      }
    ],
    "activeId": null
  },
  "agents": {
    "list": [],
    "activeId": null,
    "memories": []
  }
}
